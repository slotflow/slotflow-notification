{
  "name": "notification-backend",
  "version": "1.0.0",
  "description": "Notification backend system for Slotflow",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "predev": "npx kill-port 6000",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "build": "tsc",
    "start": "node dist/server.js",
    "bundle": "tsup src/server.ts --format esm --dts --out-dir dist-bundle"
  },
  "keywords": [
    "slotflow",
    "notification",
    "backend"
  ],
  "author": "Midhun Kalarikkal",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-ses": "^3.908.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "googleapis": "^160.0.0",
    "helmet": "^8.1.0",
    "kafkajs": "^2.2.4",
    "mongoose": "^8.10.1",
    "nodemailer": "^7.0.9",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.7.2",
    "@types/nodemailer": "^7.0.2",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.0.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0"
  }
}
